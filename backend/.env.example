# Copy this file to .env and fill in real values. Never commit .env.

PORT=4000

# Allowed origin(s) for the static storefront calling this API (comma-separated)
CORS_ORIGINS=http://localhost:3900,https://www.lufalight.com,https://lufalight.com

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE

# Stripe — Dashboard → Developers → API keys / Webhooks
STRIPE_SECRET_KEY=sk_test_PASTE_ME
STRIPE_WEBHOOK_SECRET=whsec_PASTE_ME
# Where Stripe redirects after a successful/cancelled checkout
CHECKOUT_SUCCESS_URL=https://www.lufalight.com/order-confirmed.html
CHECKOUT_CANCEL_URL=https://www.lufalight.com/shop-all.html

# Klaviyo — order confirmation email (optional in Phase 1, required by Phase 4)
KLAVIYO_API_KEY=

# Shipping carriers (Phase 2). Leave blank to use the flat-rate fallback in
# lib/shipping-rates.js — checkout works either way, but rates become real once these
# are filled in. Postal code is your warehouse/ship-from address (needed for rate quotes).
WAREHOUSE_POSTAL_CODE=
# DHL Express — developer.dhl.com → My APIs → DHL Express - MyDHL API
DHL_API_KEY=
DHL_ACCOUNT_NUMBER=
DHL_API_BASE_URL=https://express.api.dhl.com/mydhlapi/test
# FedEx Web Services — developer.fedex.com → Project → API credentials (OAuth)
FEDEX_API_KEY=
FEDEX_API_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_API_BASE_URL=https://apis-sandbox.fedex.com

# Admin access — real login via Supabase Auth, not a shared secret. Create each admin's
# account in the Supabase dashboard (Authentication → Users → Add user), then list their
# emails here (comma-separated). Only these emails can use /admin/* once logged in.
ADMIN_EMAILS=owner@lufalight.com
